{"ast":null,"code":"import { ref, reactive, computed, onMounted } from 'vue';\nimport { useStore } from 'vuex';\nimport { ElMessage } from 'element-plus';\nimport { getPredictions, runPrediction, exportPredictions } from '@/api/predictions';\nexport default {\n  name: 'SalesPrediction',\n  setup() {\n    const store = useStore();\n    const isAdmin = computed(() => store.getters.isAdmin);\n    const loading = ref(false);\n    const running = ref(false);\n    const tableData = ref([]);\n    const params = reactive({\n      start_month: '2026-03',\n      end_month: '2027-02'\n    });\n    const chartOption = ref({});\n    const buildChart = data => {\n      const months = data.map(d => d.month);\n      const values = data.map(d => d.predicted_quantity);\n      const momValues = data.map(d => d.mom_change_pct);\n      chartOption.value = {\n        tooltip: {\n          trigger: 'axis',\n          formatter: params => {\n            const d = params[0];\n            const row = data[d.dataIndex];\n            let s = `<b>${d.name}</b><br/>`;\n            s += `预测销量：<b>${d.value}</b> 万支<br/>`;\n            if (row.mom_change_pct !== null && row.mom_change_pct !== undefined) {\n              const sign = row.mom_change_pct >= 0 ? '+' : '';\n              s += `环比变化：${sign}${row.mom_change_pct}%<br/>`;\n            }\n            s += `关键因素：${row.key_factors}`;\n            return s;\n          }\n        },\n        legend: {\n          data: ['预测销量(万支)']\n        },\n        xAxis: {\n          type: 'category',\n          data: months,\n          axisLabel: {\n            rotate: 30,\n            fontSize: 11\n          }\n        },\n        yAxis: [{\n          type: 'value',\n          name: '销量(万支)',\n          min: 40\n        }],\n        series: [{\n          name: '预测销量(万支)',\n          type: 'line',\n          data: values,\n          smooth: true,\n          lineStyle: {\n            color: '#e6a23c',\n            width: 3\n          },\n          itemStyle: {\n            color: '#e6a23c'\n          },\n          areaStyle: {\n            opacity: 0.12,\n            color: '#e6a23c'\n          },\n          markPoint: {\n            data: [{\n              type: 'max',\n              name: '最高',\n              itemStyle: {\n                color: '#f56c6c'\n              }\n            }, {\n              type: 'min',\n              name: '最低',\n              itemStyle: {\n                color: '#409eff'\n              }\n            }]\n          },\n          label: {\n            show: true,\n            formatter: '{c}',\n            fontSize: 11,\n            position: 'top'\n          }\n        }],\n        grid: {\n          left: 60,\n          right: 30,\n          bottom: 60,\n          top: 40\n        }\n      };\n    };\n    const loadPredictions = async () => {\n      loading.value = true;\n      try {\n        const res = await getPredictions({\n          start_month: params.start_month,\n          end_month: params.end_month\n        });\n        tableData.value = res.data;\n        if (res.data.length > 0) {\n          buildChart(res.data);\n        }\n      } finally {\n        loading.value = false;\n      }\n    };\n    const handleRun = async () => {\n      running.value = true;\n      try {\n        const res = await runPrediction({\n          start_month: params.start_month,\n          end_month: params.end_month\n        });\n        ElMessage.success(res.data.detail);\n        await loadPredictions();\n      } catch (e) {\n        ElMessage.error(e.response?.data?.detail || '预测失败');\n      } finally {\n        running.value = false;\n      }\n    };\n    const handleExport = async () => {\n      const res = await exportPredictions({\n        start_month: params.start_month,\n        end_month: params.end_month\n      });\n      const url = URL.createObjectURL(new Blob([res.data]));\n      const a = document.createElement('a');\n      a.href = url;\n      a.download = 'prediction_results.csv';\n      a.click();\n      URL.revokeObjectURL(url);\n    };\n    onMounted(loadPredictions);\n    return {\n      isAdmin,\n      loading,\n      running,\n      tableData,\n      params,\n      chartOption,\n      loadPredictions,\n      handleRun,\n      handleExport\n    };\n  }\n};","map":{"version":3,"names":["ref","reactive","computed","onMounted","useStore","ElMessage","getPredictions","runPrediction","exportPredictions","name","setup","store","isAdmin","getters","loading","running","tableData","params","start_month","end_month","chartOption","buildChart","data","months","map","d","month","values","predicted_quantity","momValues","mom_change_pct","value","tooltip","trigger","formatter","row","dataIndex","s","undefined","sign","key_factors","legend","xAxis","type","axisLabel","rotate","fontSize","yAxis","min","series","smooth","lineStyle","color","width","itemStyle","areaStyle","opacity","markPoint","label","show","position","grid","left","right","bottom","top","loadPredictions","res","length","handleRun","success","detail","e","error","response","handleExport","url","URL","createObjectURL","Blob","a","document","createElement","href","download","click","revokeObjectURL"],"sources":["E:\\Program Files (x86)\\PyCharm 2025.1.1.1\\claude\\guangzhou-yunnan-sales\\frontend\\src\\views\\Prediction\\SalesPrediction.vue"],"sourcesContent":["<template>\n  <div class=\"prediction-page\">\n    <!-- 参数设置 -->\n    <el-card shadow=\"never\" class=\"param-card\">\n      <template #header><span>预测参数设置</span></template>\n      <el-form :inline=\"true\" :model=\"params\">\n        <el-form-item label=\"预测开始月份\">\n          <el-date-picker\n            v-model=\"params.start_month\"\n            type=\"month\"\n            value-format=\"YYYY-MM\"\n            placeholder=\"选择月份\"\n            style=\"width:140px\"\n          />\n        </el-form-item>\n        <el-form-item label=\"预测结束月份\">\n          <el-date-picker\n            v-model=\"params.end_month\"\n            type=\"month\"\n            value-format=\"YYYY-MM\"\n            placeholder=\"选择月份\"\n            style=\"width:140px\"\n          />\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" icon=\"DataAnalysis\" :loading=\"running\" @click=\"handleRun\" v-if=\"isAdmin\">\n            执行预测\n          </el-button>\n          <el-button type=\"success\" icon=\"Download\" @click=\"handleExport\">导出结果</el-button>\n          <el-button @click=\"loadPredictions\">刷新数据</el-button>\n        </el-form-item>\n      </el-form>\n      <div class=\"model-info\">\n        <el-tag type=\"info\" size=\"small\">预测模型：SARIMA季节分解模型</el-tag>\n        <el-text type=\"info\" size=\"small\" style=\"margin-left:12px\">\n          基于2024-2025年历史销量数据，结合季节性指数与节假日效应进行预测\n        </el-text>\n      </div>\n    </el-card>\n\n    <!-- 预测图表 -->\n    <el-card shadow=\"never\" class=\"chart-card\" style=\"margin-top:16px\">\n      <template #header><span>销量预测折线图（万支）</span></template>\n      <v-chart :option=\"chartOption\" style=\"height:320px\" autoresize />\n    </el-card>\n\n    <!-- 预测结果表 -->\n    <el-card shadow=\"never\" class=\"table-card\" style=\"margin-top:16px\">\n      <template #header>\n        <div class=\"card-header\">\n          <span>2026年3月 - 2027年2月 销量预测表</span>\n          <el-tag type=\"success\" size=\"small\">共{{ tableData.length }}条预测记录</el-tag>\n        </div>\n      </template>\n      <el-table :data=\"tableData\" v-loading=\"loading\" border stripe style=\"width:100%\">\n        <el-table-column prop=\"month\" label=\"月份\" width=\"110\" />\n        <el-table-column label=\"预测销量(万支)\" width=\"140\" align=\"right\">\n          <template #default=\"{ row }\">\n            <span class=\"qty-val\">{{ row.predicted_quantity }}</span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"环比变化\" width=\"120\" align=\"center\">\n          <template #default=\"{ row }\">\n            <span v-if=\"row.mom_change_pct === null || row.mom_change_pct === undefined\">–</span>\n            <el-tag\n              v-else\n              :type=\"row.mom_change_pct >= 0 ? 'success' : 'danger'\"\n              size=\"small\"\n            >\n              {{ row.mom_change_pct >= 0 ? '+' : '' }}{{ row.mom_change_pct }}%\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"key_factors\" label=\"预测关键因素\" min-width=\"180\" />\n        <el-table-column prop=\"model_type\" label=\"预测模型\" width=\"110\" />\n      </el-table>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport { ref, reactive, computed, onMounted } from 'vue'\nimport { useStore } from 'vuex'\nimport { ElMessage } from 'element-plus'\nimport { getPredictions, runPrediction, exportPredictions } from '@/api/predictions'\n\nexport default {\n  name: 'SalesPrediction',\n  setup() {\n    const store = useStore()\n    const isAdmin = computed(() => store.getters.isAdmin)\n    const loading = ref(false)\n    const running = ref(false)\n    const tableData = ref([])\n    const params = reactive({ start_month: '2026-03', end_month: '2027-02' })\n    const chartOption = ref({})\n\n    const buildChart = (data) => {\n      const months = data.map(d => d.month)\n      const values = data.map(d => d.predicted_quantity)\n      const momValues = data.map(d => d.mom_change_pct)\n\n      chartOption.value = {\n        tooltip: {\n          trigger: 'axis',\n          formatter: (params) => {\n            const d = params[0]\n            const row = data[d.dataIndex]\n            let s = `<b>${d.name}</b><br/>`\n            s += `预测销量：<b>${d.value}</b> 万支<br/>`\n            if (row.mom_change_pct !== null && row.mom_change_pct !== undefined) {\n              const sign = row.mom_change_pct >= 0 ? '+' : ''\n              s += `环比变化：${sign}${row.mom_change_pct}%<br/>`\n            }\n            s += `关键因素：${row.key_factors}`\n            return s\n          }\n        },\n        legend: { data: ['预测销量(万支)'] },\n        xAxis: { type: 'category', data: months, axisLabel: { rotate: 30, fontSize: 11 } },\n        yAxis: [\n          { type: 'value', name: '销量(万支)', min: 40 },\n        ],\n        series: [{\n          name: '预测销量(万支)',\n          type: 'line',\n          data: values,\n          smooth: true,\n          lineStyle: { color: '#e6a23c', width: 3 },\n          itemStyle: { color: '#e6a23c' },\n          areaStyle: { opacity: 0.12, color: '#e6a23c' },\n          markPoint: {\n            data: [\n              { type: 'max', name: '最高', itemStyle: { color: '#f56c6c' } },\n              { type: 'min', name: '最低', itemStyle: { color: '#409eff' } },\n            ]\n          },\n          label: { show: true, formatter: '{c}', fontSize: 11, position: 'top' },\n        }],\n        grid: { left: 60, right: 30, bottom: 60, top: 40 },\n      }\n    }\n\n    const loadPredictions = async () => {\n      loading.value = true\n      try {\n        const res = await getPredictions({\n          start_month: params.start_month,\n          end_month: params.end_month,\n        })\n        tableData.value = res.data\n        if (res.data.length > 0) {\n          buildChart(res.data)\n        }\n      } finally {\n        loading.value = false\n      }\n    }\n\n    const handleRun = async () => {\n      running.value = true\n      try {\n        const res = await runPrediction({\n          start_month: params.start_month,\n          end_month: params.end_month,\n        })\n        ElMessage.success(res.data.detail)\n        await loadPredictions()\n      } catch (e) {\n        ElMessage.error(e.response?.data?.detail || '预测失败')\n      } finally {\n        running.value = false\n      }\n    }\n\n    const handleExport = async () => {\n      const res = await exportPredictions({\n        start_month: params.start_month,\n        end_month: params.end_month,\n      })\n      const url = URL.createObjectURL(new Blob([res.data]))\n      const a = document.createElement('a')\n      a.href = url\n      a.download = 'prediction_results.csv'\n      a.click()\n      URL.revokeObjectURL(url)\n    }\n\n    onMounted(loadPredictions)\n\n    return { isAdmin, loading, running, tableData, params, chartOption, loadPredictions, handleRun, handleExport }\n  }\n}\n</script>\n\n<style scoped>\n.prediction-page { padding: 4px; }\n.param-card { }\n.card-header { display: flex; justify-content: space-between; align-items: center; }\n.model-info { margin-top: 12px; display: flex; align-items: center; }\n.qty-val { font-weight: 600; color: #e6a23c; font-size: 15px; }\n</style>\n"],"mappings":"AAiFA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,QAAQ,EAAEC,SAAQ,QAAS,KAAI;AACvD,SAASC,QAAO,QAAS,MAAK;AAC9B,SAASC,SAAQ,QAAS,cAAa;AACvC,SAASC,cAAc,EAAEC,aAAa,EAAEC,iBAAgB,QAAS,mBAAkB;AAEnF,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,KAAKA,CAAA,EAAG;IACN,MAAMC,KAAI,GAAIP,QAAQ,CAAC;IACvB,MAAMQ,OAAM,GAAIV,QAAQ,CAAC,MAAMS,KAAK,CAACE,OAAO,CAACD,OAAO;IACpD,MAAME,OAAM,GAAId,GAAG,CAAC,KAAK;IACzB,MAAMe,OAAM,GAAIf,GAAG,CAAC,KAAK;IACzB,MAAMgB,SAAQ,GAAIhB,GAAG,CAAC,EAAE;IACxB,MAAMiB,MAAK,GAAIhB,QAAQ,CAAC;MAAEiB,WAAW,EAAE,SAAS;MAAEC,SAAS,EAAE;IAAU,CAAC;IACxE,MAAMC,WAAU,GAAIpB,GAAG,CAAC,CAAC,CAAC;IAE1B,MAAMqB,UAAS,GAAKC,IAAI,IAAK;MAC3B,MAAMC,MAAK,GAAID,IAAI,CAACE,GAAG,CAACC,CAAA,IAAKA,CAAC,CAACC,KAAK;MACpC,MAAMC,MAAK,GAAIL,IAAI,CAACE,GAAG,CAACC,CAAA,IAAKA,CAAC,CAACG,kBAAkB;MACjD,MAAMC,SAAQ,GAAIP,IAAI,CAACE,GAAG,CAACC,CAAA,IAAKA,CAAC,CAACK,cAAc;MAEhDV,WAAW,CAACW,KAAI,GAAI;QAClBC,OAAO,EAAE;UACPC,OAAO,EAAE,MAAM;UACfC,SAAS,EAAGjB,MAAM,IAAK;YACrB,MAAMQ,CAAA,GAAIR,MAAM,CAAC,CAAC;YAClB,MAAMkB,GAAE,GAAIb,IAAI,CAACG,CAAC,CAACW,SAAS;YAC5B,IAAIC,CAAA,GAAI,MAAMZ,CAAC,CAAChB,IAAI,WAAU;YAC9B4B,CAAA,IAAK,WAAWZ,CAAC,CAACM,KAAK,cAAa;YACpC,IAAII,GAAG,CAACL,cAAa,KAAM,IAAG,IAAKK,GAAG,CAACL,cAAa,KAAMQ,SAAS,EAAE;cACnE,MAAMC,IAAG,GAAIJ,GAAG,CAACL,cAAa,IAAK,IAAI,GAAE,GAAI,EAAC;cAC9CO,CAAA,IAAK,QAAQE,IAAI,GAAGJ,GAAG,CAACL,cAAc,QAAO;YAC/C;YACAO,CAAA,IAAK,QAAQF,GAAG,CAACK,WAAW,EAAC;YAC7B,OAAOH,CAAA;UACT;QACF,CAAC;QACDI,MAAM,E
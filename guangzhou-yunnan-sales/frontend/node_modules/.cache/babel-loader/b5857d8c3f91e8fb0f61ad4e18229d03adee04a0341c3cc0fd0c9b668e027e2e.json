{"ast":null,"code":"import { ref, reactive, onMounted } from 'vue';\nimport { ElMessage, ElMessageBox } from 'element-plus';\nimport { getUsers, createUser, updateUser } from '@/api/users';\nexport default {\n  name: 'UserManagement',\n  setup() {\n    const loading = ref(false);\n    const tableData = ref([]);\n    const filter = reactive({\n      keyword: '',\n      role: ''\n    });\n    const dialogVisible = ref(false);\n    const editMode = ref(false);\n    const editId = ref(null);\n    const dialogFormRef = ref(null);\n    const submitLoading = ref(false);\n    const dialogForm = reactive({\n      username: '',\n      full_name: '',\n      email: '',\n      role: 'operator',\n      password: ''\n    });\n    const dialogRules = {\n      username: [{\n        required: true,\n        message: '请输入用户名',\n        trigger: 'blur'\n      }],\n      full_name: [{\n        required: true,\n        message: '请输入姓名',\n        trigger: 'blur'\n      }],\n      role: [{\n        required: true,\n        message: '请选择角色',\n        trigger: 'change'\n      }],\n      password: [{\n        required: true,\n        message: '请输入密码',\n        min: 6,\n        trigger: 'blur'\n      }]\n    };\n    const loadData = async () => {\n      loading.value = true;\n      try {\n        const res = await getUsers(filter);\n        tableData.value = res.data.results || res.data;\n      } finally {\n        loading.value = false;\n      }\n    };\n    const resetFilter = () => {\n      filter.keyword = '';\n      filter.role = '';\n      loadData();\n    };\n    const openAddDialog = () => {\n      editMode.value = false;\n      editId.value = null;\n      Object.assign(dialogForm, {\n        username: '',\n        full_name: '',\n        email: '',\n        role: 'operator',\n        password: ''\n      });\n      dialogVisible.value = true;\n    };\n    const openEditDialog = row => {\n      editMode.value = true;\n      editId.value = row.id;\n      Object.assign(dialogForm, {\n        username: row.username,\n        full_name: row.full_name,\n        email: row.email,\n        role: row.role,\n        password: ''\n      });\n      dialogVisible.value = true;\n    };\n    const handleSubmit = async () => {\n      await dialogFormRef.value.validate();\n      submitLoading.value = true;\n      const data = {\n        ...dialogForm\n      };\n      if (editMode.value && !data.password) delete data.password;\n      try {\n        if (editMode.value) {\n          await updateUser(editId.value, data);\n          ElMessage.success('用户更新成功');\n        } else {\n          await createUser(data);\n          ElMessage.success('用户创建成功');\n        }\n        dialogVisible.value = false;\n        loadData();\n      } finally {\n        submitLoading.value = false;\n      }\n    };\n    const handleToggleActive = async row => {\n      const action = row.is_active ? '禁用' : '启用';\n      await ElMessageBox.confirm(`确定${action}用户 ${row.username} 吗？`, '确认', {\n        type: 'warning'\n      });\n      await updateUser(row.id, {\n        is_active: !row.is_active\n      });\n      ElMessage.success(`${action}成功`);\n      loadData();\n    };\n    onMounted(loadData);\n    return {\n      loading,\n      tableData,\n      filter,\n      dialogVisible,\n      editMode,\n      dialogFormRef,\n      submitLoading,\n      dialogForm,\n      dialogRules,\n      loadData,\n      resetFilter,\n      openAddDialog,\n      openEditDialog,\n      handleSubmit,\n      handleToggleActive\n    };\n  }\n};","map":{"version":3,"names":["ref","reactive","onMounted","ElMessage","ElMessageBox","getUsers","createUser","updateUser","name","setup","loading","tableData","filter","keyword","role","dialogVisible","editMode","editId","dialogFormRef","submitLoading","dialogForm","username","full_name","email","password","dialogRules","required","message","trigger","min","loadData","value","res","data","results","resetFilter","openAddDialog","Object","assign","openEditDialog","row","id","handleSubmit","validate","success","handleToggleActive","action","is_active","confirm","type"],"sources":["D:\\相关软件\\云南白药预测系统\\guangzhou-yunnan-sales\\frontend\\src\\views\\Users\\UserManagement.vue"],"sourcesContent":["<template>\n  <div class=\"users-page\">\n    <el-card shadow=\"never\">\n      <template #header>\n        <div class=\"card-header\">\n          <span>用户管理</span>\n          <el-button type=\"primary\" icon=\"Plus\" @click=\"openAddDialog\">新增用户</el-button>\n        </div>\n      </template>\n\n      <!-- 搜索栏 -->\n      <el-form :inline=\"true\" :model=\"filter\" class=\"filter-form\">\n        <el-form-item>\n          <el-input v-model=\"filter.keyword\" placeholder=\"用户名/姓名\" clearable prefix-icon=\"Search\" style=\"width:180px\" @keyup.enter=\"loadData\" />\n        </el-form-item>\n        <el-form-item>\n          <el-select v-model=\"filter.role\" placeholder=\"角色\" clearable style=\"width:120px\">\n            <el-option label=\"管理员\" value=\"admin\" />\n            <el-option label=\"操作员\" value=\"operator\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" icon=\"Search\" @click=\"loadData\">查询</el-button>\n          <el-button icon=\"Refresh\" @click=\"resetFilter\">重置</el-button>\n        </el-form-item>\n      </el-form>\n\n      <!-- 用户表格 -->\n      <el-table :data=\"tableData\" v-loading=\"loading\" border stripe>\n        <el-table-column prop=\"id\" label=\"ID\" width=\"60\" />\n        <el-table-column prop=\"username\" label=\"用户名\" width=\"130\" />\n        <el-table-column prop=\"full_name\" label=\"姓名\" width=\"110\" />\n        <el-table-column prop=\"email\" label=\"邮箱\" min-width=\"180\" />\n        <el-table-column label=\"角色\" width=\"100\">\n          <template #default=\"{ row }\">\n            <el-tag :type=\"row.role === 'admin' ? 'danger' : 'primary'\" size=\"small\">\n              {{ row.role_display }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"状态\" width=\"80\">\n          <template #default=\"{ row }\">\n            <el-tag :type=\"row.is_active ? 'success' : 'info'\" size=\"small\">\n              {{ row.is_active ? '启用' : '禁用' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"created_at\" label=\"创建时间\" width=\"170\" />\n        <el-table-column label=\"操作\" width=\"150\" fixed=\"right\">\n          <template #default=\"{ row }\">\n            <el-button type=\"primary\" size=\"small\" text @click=\"openEditDialog(row)\">编辑</el-button>\n            <el-button\n              :type=\"row.is_active ? 'warning' : 'success'\"\n              size=\"small\" text\n              @click=\"handleToggleActive(row)\"\n            >\n              {{ row.is_active ? '禁用' : '启用' }}\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n\n    <!-- 新增/编辑弹窗 -->\n    <el-dialog v-model=\"dialogVisible\" :title=\"editMode ? '编辑用户' : '新增用户'\" width=\"480px\">\n      <el-form ref=\"dialogFormRef\" :model=\"dialogForm\" :rules=\"dialogRules\" label-width=\"80px\">\n        <el-form-item label=\"用户名\" prop=\"username\">\n          <el-input v-model=\"dialogForm.username\" :disabled=\"editMode\" />\n        </el-form-item>\n        <el-form-item label=\"姓名\" prop=\"full_name\">\n          <el-input v-model=\"dialogForm.full_name\" />\n        </el-form-item>\n        <el-form-item label=\"邮箱\">\n          <el-input v-model=\"dialogForm.email\" />\n        </el-form-item>\n        <el-form-item label=\"角色\" prop=\"role\">\n          <el-select v-model=\"dialogForm.role\" style=\"width:100%\">\n            <el-option label=\"管理员\" value=\"admin\" />\n            <el-option label=\"操作员\" value=\"operator\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item :label=\"editMode ? '新密码' : '密码'\" :prop=\"editMode ? '' : 'password'\">\n          <el-input v-model=\"dialogForm.password\" type=\"password\" show-password :placeholder=\"editMode ? '不修改留空' : '至少6位'\" />\n        </el-form-item>\n      </el-form>\n      <template #footer>\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" :loading=\"submitLoading\" @click=\"handleSubmit\">确定</el-button>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { ref, reactive, onMounted } from 'vue'\nimport { ElMessage, ElMessageBox } from 'element-plus'\nimport { getUsers, createUser, updateUser } from '@/api/users'\n\nexport default {\n  name: 'UserManagement',\n  setup() {\n    const loading = ref(false)\n    const tableData = ref([])\n    const filter = reactive({ keyword: '', role: '' })\n    const dialogVisible = ref(false)\n    const editMode = ref(false)\n    const editId = ref(null)\n    const dialogFormRef = ref(null)\n    const submitLoading = ref(false)\n    const dialogForm = reactive({ username: '', full_name: '', email: '', role: 'operator', password: '' })\n\n    const dialogRules = {\n      username: [{ required: true, message: '请输入用户名', trigger: 'blur' }],\n      full_name: [{ required: true, message: '请输入姓名', trigger: 'blur' }],\n      role: [{ required: true, message: '请选择角色', trigger: 'change' }],\n      password: [{ required: true, message: '请输入密码', min: 6, trigger: 'blur' }],\n    }\n\n    const loadData = async () => {\n      loading.value = true\n      try {\n        const res = await getUsers(filter)\n        tableData.value = res.data.results || res.data\n      } finally {\n        loading.value = false\n      }\n    }\n\n    const resetFilter = () => {\n      filter.keyword = ''\n      filter.role = ''\n      loadData()\n    }\n\n    const openAddDialog = () => {\n      editMode.value = false\n      editId.value = null\n      Object.assign(dialogForm, { username: '', full_name: '', email: '', role: 'operator', password: '' })\n      dialogVisible.value = true\n    }\n\n    const openEditDialog = (row) => {\n      editMode.value = true\n      editId.value = row.id\n      Object.assign(dialogForm, { username: row.username, full_name: row.full_name, email: row.email, role: row.role, password: '' })\n      dialogVisible.value = true\n    }\n\n    const handleSubmit = async () => {\n      await dialogFormRef.value.validate()\n      submitLoading.value = true\n      const data = { ...dialogForm }\n      if (editMode.value && !data.password) delete data.password\n      try {\n        if (editMode.value) {\n          await updateUser(editId.value, data)\n          ElMessage.success('用户更新成功')\n        } else {\n          await createUser(data)\n          ElMessage.success('用户创建成功')\n        }\n        dialogVisible.value = false\n        loadData()\n      } finally {\n        submitLoading.value = false\n      }\n    }\n\n    const handleToggleActive = async (row) => {\n      const action = row.is_active ? '禁用' : '启用'\n      await ElMessageBox.confirm(`确定${action}用户 ${row.username} 吗？`, '确认', { type: 'warning' })\n      await updateUser(row.id, { is_active: !row.is_active })\n      ElMessage.success(`${action}成功`)\n      loadData()\n    }\n\n    onMounted(loadData)\n\n    return {\n      loading, tableData, filter, dialogVisible, editMode, dialogFormRef,\n      submitLoading, dialogForm, dialogRules,\n      loadData, resetFilter, openAddDialog, openEditDialog, handleSubmit, handleToggleActive\n    }\n  }\n}\n</script>\n\n<style scoped>\n.card-header { display: flex; justify-content: space-between; align-items: center; }\n.filter-form { margin-bottom: 12px; }\n</style>\n"],"mappings":"AA8FA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAQ,QAAS,KAAI;AAC7C,SAASC,SAAS,EAAEC,YAAW,QAAS,cAAa;AACrD,SAASC,QAAQ,EAAEC,UAAU,EAAEC,UAAS,QAAS,aAAY;AAE7D,eAAe;EACbC,IAAI,EAAE,gBAAgB;EACtBC,KAAKA,CAAA,EAAG;IACN,MAAMC,OAAM,GAAIV,GAAG,CAAC,KAAK;IACzB,MAAMW,SAAQ,GAAIX,GAAG,CAAC,EAAE;IACxB,MAAMY,MAAK,GAAIX,QAAQ,CAAC;MAAEY,OAAO,EAAE,EAAE;MAAEC,IAAI,EAAE;IAAG,CAAC